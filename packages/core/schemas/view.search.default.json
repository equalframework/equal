{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:equal:json-schema:core:view.search.default",
  "title": "eQual Search View",
  "description": "Schema for eQual search/filter views (*.search.*.json files)",
  "type": "object",
  "required": ["name", "layout"],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "description": "Search view identifier"
    },
    "entity": {
      "type": "string",
      "description": "Entity class this search applies to"
    },
    "context": {
      "type": "string"
    },
    "order": {
      "type": "string",
      "description": "Default sort field"
    },
    "sort": {
      "type": "string",
      "enum": ["asc", "desc"],
      "description": "Default sort direction"
    },
    "start": {
      "type": "integer",
      "description": "Pagination start offset"
    },
    "limit": {
      "type": "integer",
      "description": "Pagination limit"
    },
    "domain": {
      "type": "array",
      "description": "Default filter domain clause"
    },
    "layout": {
      "type": "object",
      "properties": {
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "label": {"type": "string"},
              "sections": {
                "type": "array",
                "items": {"$ref": "#/$defs/section"}
              }
            }
          },
          "description": "Grouped sections (form-like layout)"
        },
        "sections": {
          "type": "array",
          "items": {"$ref": "#/$defs/section"},
          "description": "Collapsible filter sections (flat layout)"
        }
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "description": {"type": "string"},
        "collapsible": {"type": "boolean"},
        "expanded": {"type": "boolean"},
        "rows": {
          "type": "array",
          "description": "Rows in form-like search layout"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "field": {"type": "string"},
              "label": {"type": "string"},
              "type": {
                "type": "string",
                "enum": ["text", "select", "date", "daterange", "number", "checkbox"]
              },
              "operator": {
                "type": "string",
                "enum": ["contains", "eq", "gt", "gte", "lt", "lte", "in", "like", "between"]
              },
              "widget": {
                "type": "object",
                "properties": {
                  "type": {"type": "string"},
                  "values": {
                    "oneOf": [
                      {"type": "array"},
                      {"type": "object"}
                    ],
                    "description": "Select/dropdown options (array of values or object with labels)"
                  }
                }
              },
              "placeholder": {"type": "string"}
            }
          },
          "description": "Search filter fields (simple search layout)"
        }
      }
    }
  },
  "additionalProperties": true
}
